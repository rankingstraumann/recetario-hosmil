+async function enviarAutomaticamente() {
+  const q = state.activeQuote; if (!q) return;
+  if (!q.pacienteEmail) { state.sendError = 'Esta cotización no tiene correo del paciente.'; renderCompartir(); return; }
+  if (!q.dbId) { state.sendError = 'Esta cotización no quedó guardada en el sistema. Usa "Copiar link" o los botones manuales de abajo.'; renderCompartir(); return; }
+
+  state.sendError = ''; state.notifMsg = ''; state.enviandoAuto = true;
+  renderCompartir();
+
+  try {
+    const { data, error } = await sb.functions.invoke('enviar-cotizacion', {
+      body: { cotizacion_id: q.dbId }
+    });
+
+    if (error || !data || data.ok !== true) {
+      const msg = (data && data.error) || (error && error.message) || 'No se pudo enviar el correo automáticamente.';
+      state.sendError = msg + ' Puedes usar "Copiar link" o los botones manuales de abajo mientras tanto.';
+      state.enviandoAuto = false;
+      renderCompartir();
+      return;
+    }
+
+    // Estado solo se refleja localmente después de la confirmación real del backend
+    // (la Edge Function ya actualizó `estado` en la base de datos porque Resend respondió OK).
+    q.estado = 'Enviada al paciente';
+    q.historial.push({ estado: 'Enviada al paciente', fecha: new Date().toISOString(), canal: 'automatico' });
+    state.notifMsg = 'Correo enviado automáticamente al paciente desde cotizaciones@recetariostra.cl.';
+    state.enviandoAuto = false;
+    renderCompartir();
+  } catch (e) {
+    state.sendError = 'Error de red al intentar el envío automático. Puedes usar "Copiar link" o los botones manuales de abajo mientras tanto.';
+    state.enviandoAuto = false;
+    renderCompartir();
+  }
+}
